@model LibrarySettings
@{
    ViewData["Title"] = "Edit Settings";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card-surface p-4 p-md-5">
            <h2 class="panel-title mb-4">Edit circulation rules</h2>
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="LibrarySettingsId" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="DefaultLoanDays" class="form-label"></label>
                    <input asp-for="DefaultLoanDays" class="form-control" />
                    <span asp-validation-for="DefaultLoanDays" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="MaxConcurrentLoansPerMember" class="form-label"></label>
                    <input asp-for="MaxConcurrentLoansPerMember" class="form-control" />
                    <span asp-validation-for="MaxConcurrentLoansPerMember" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="DailyFineAmount" class="form-label"></label>
                    <input asp-for="DailyFineAmount" class="form-control" />
                    <span asp-validation-for="DailyFineAmount" class="text-danger"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save settings</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
