@model Book
@{
    ViewData["Title"] = Model.Title;
    var borrowedIds = ViewBag.BorrowedCopyIds as HashSet<int> ?? new HashSet<int>();
    var available = Model.Items.Count(i => !borrowedIds.Contains(i.BookItemId));
}

<div class="card-surface p-4 p-md-5 mb-4">
    <div class="d-flex flex-wrap justify-content-between gap-3">
        <div>
            <h2 class="panel-title mb-1">@Model.Title</h2>
            <p class="text-muted mb-2">@Model.Author.FullName · @Model.Category.Name · @Model.PublishedYear</p>
            <p class="mb-0">@Model.Summary</p>
        </div>
        <div class="text-end">
            <span class="badge badge-status @(available > 0 ? "badge-returned" : "badge-overdue")">@(available > 0 ? $"{available} available" : "Unavailable")</span>
            <div class="mt-3 d-flex gap-2 justify-content-end">
                @if (available > 0)
                {
                    <form asp-action="Borrow" asp-route-id="@Model.BookId" method="post">
                        <button type="submit" class="btn btn-primary">Borrow book</button>
                    </form>
                }
                <form asp-action="Reserve" asp-route-id="@Model.BookId" method="post">
                    <button type="submit" class="btn btn-outline-secondary">Reserve</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="card-surface table-card">
    <div class="table-responsive">
        <table class="table table-modern align-middle mb-0">
            <thead><tr><th>Copy</th><th>Branch</th><th>Shelf</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var copy in Model.Items.OrderBy(i => i.Barcode))
                {
                    var isBorrowed = borrowedIds.Contains(copy.BookItemId);
                    <tr>
                        <td class="font-monospace small">@copy.Barcode</td>
                        <td>@copy.Branch.Name</td>
                        <td class="text-muted">@copy.ShelfLocation</td>
                        <td><span class="badge badge-status @(isBorrowed ? "badge-borrowed" : "badge-returned")">@(isBorrowed ? "Borrowed" : "Available")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
