<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Lumina Library</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="mobile-topbar d-lg-none" role="banner">
        <div class="mobile-topbar-inner">
            <button type="button"
                    class="mobile-nav-trigger btn btn-icon"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#mobileNav"
                    aria-controls="mobileNav"
                    aria-label="Open menu">
                <i class="bi bi-list" aria-hidden="true"></i>
            </button>
            <a class="mobile-topbar-brand text-decoration-none" asp-controller="Home" asp-action="Index">
                <span class="mobile-topbar-icon"><i class="bi bi-book-half"></i></span>
                <span class="mobile-topbar-title">Lumina</span>
            </a>
            <button type="button"
                    class="btn btn-icon mobile-theme-toggle"
                    data-theme-toggle
                    title="Toggle theme"
                    aria-label="Toggle dark mode">
                <i class="bi bi-moon-stars" aria-hidden="true"></i>
            </button>
        </div>
    </header>

    <div class="offcanvas offcanvas-start nav-drawer d-lg-none" tabindex="-1" id="mobileNav" aria-labelledby="mobileNavLabel">
        <div class="offcanvas-header border-bottom border-opacity-10">
            <div id="mobileNavLabel" class="offcanvas-title d-flex align-items-center gap-2 mb-0">
                <span class="sidebar-brand-icon"><i class="bi bi-book-half"></i></span>
                <span class="fw-semibold">Library suite</span>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close menu"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column py-3">
            <nav class="sidebar-nav flex-grow-1">
                <partial name="_MainNavigation" />
            </nav>
            <div class="sidebar-footer border-top border-opacity-10 mt-2 pt-3">
                <button type="button" class="btn btn-theme w-100" data-theme-toggle title="Toggle theme">
                    <i class="bi bi-moon-stars me-1"></i><span class="theme-label">Dark mode</span>
                </button>
            </div>
        </div>
    </div>

    <div class="app-shell">
        <aside class="sidebar d-none d-lg-flex">
            <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                <span class="sidebar-brand-icon"><i class="bi bi-book-half"></i></span>
                <span>
                    <span class="sidebar-brand-title">Lumina</span>
                    <span class="sidebar-brand-sub">Library suite</span>
                </span>
            </a>
            <nav class="sidebar-nav flex-grow-1">
                <partial name="_MainNavigation" />
            </nav>
            <div class="sidebar-footer">
                <button type="button" class="btn btn-theme w-100" data-theme-toggle title="Toggle theme">
                    <i class="bi bi-moon-stars me-1"></i><span class="theme-label">Dark mode</span>
                </button>
            </div>
        </aside>
        <div class="main-area">
            <header class="page-header">
                <div class="page-header-text">
                    <p class="page-kicker mb-0">Library operations</p>
                    <h1 class="page-title">@ViewData["Title"]</h1>
                </div>
                <div class="page-actions d-none d-md-flex align-items-center gap-3 flex-wrap justify-content-end">
                    <span class="text-muted small page-date">@DateTime.Now.ToString("dddd, MMMM d")</span>
                </div>
            </header>
            <main class="page-content">
                <partial name="_Alerts" />
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
