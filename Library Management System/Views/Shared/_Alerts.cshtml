@using System.Notifications
@using System.Text.Json
@{
    var messages = new List<SnackbarMessage>();
    if (TempData["SnackbarMessages"] is string json && !string.IsNullOrWhiteSpace(json))
    {
        messages.AddRange(JsonSerializer.Deserialize<List<SnackbarMessage>>(json) ?? new List<SnackbarMessage>());
    }

    if (TempData["Success"] is string ok)
        messages.Add(new SnackbarMessage("success", ok));
    if (TempData["Warning"] is string warn)
        messages.Add(new SnackbarMessage("warning", warn));
    if (TempData["Error"] is string err)
        messages.Add(new SnackbarMessage("danger", err));
}

@if (messages.Count > 0)
{
    <div class="snackbar-stack" aria-live="polite" aria-atomic="true">
        @foreach (var item in messages)
        {
            var icon = item.Kind switch
            {
                "success" => "bi-check-circle-fill",
                "warning" => "bi-exclamation-triangle-fill",
                "danger" => "bi-x-circle-fill",
                _ => "bi-info-circle-fill"
            };
            <div class="snackbar snackbar-@item.Kind" role="status" data-snackbar>
                <i class="bi @icon flex-shrink-0"></i>
                <div class="snackbar-message">@item.Message</div>
                <button type="button" class="snackbar-close" data-snackbar-close aria-label="Dismiss notification">
                    <i class="bi bi-x"></i>
                </button>
            </div>
        }
    </div>
}
