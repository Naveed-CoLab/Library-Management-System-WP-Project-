@model System.Models.Author
@{ ViewData["Title"] = "Author profile"; }
<div class="card-surface p-4 mb-4">
    <dl class="row mb-0 small">
        <dt class="col-sm-3 text-muted">Name</dt><dd class="col-sm-9 fw-semibold">@Model.FullName</dd>
        <dt class="col-sm-3 text-muted">Nationality</dt><dd class="col-sm-9">@(Model.Nationality ?? "—")</dd>
        <dt class="col-sm-3 text-muted">Born</dt><dd class="col-sm-9">@Model.DateOfBirth</dd>
    </dl>
    <div class="mt-3 d-flex flex-wrap gap-2">
        <a asp-action="Edit" asp-route-id="@Model.AuthorId" class="btn btn-primary btn-sm">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
    </div>
</div>
<div class="card-surface table-card p-3 p-md-4">
    <h3 class="h6 mb-3" style="font-family:var(--font-display); font-weight:600;">Works in catalogue</h3>
    @if (Model.Books.Any())
    {
        <div class="table-responsive">
            <table class="table table-modern mb-0">
                <thead><tr><th>Title</th><th>Category</th><th>Year</th><th></th></tr></thead>
                <tbody>
                    @foreach (var book in Model.Books.OrderBy(b => b.Title))
                    {
                        <tr>
                            <td class="fw-semibold">@book.Title</td>
                            <td class="text-muted">@(book.Category?.Name ?? "—")</td>
                            <td>@book.PublishedYear</td>
                            <td class="text-end"><a asp-controller="Books" asp-action="Details" asp-route-id="@book.BookId" class="btn btn-outline-secondary btn-sm">Open</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted small mb-0">No titles linked yet.</p>
    }
</div>
