@model System.Models.Author
@{ ViewData["Title"] = "Add author"; }
<div class="card-surface form-card p-4">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <div class="mb-3"><label asp-for="FullName" class="form-label"></label><input asp-for="FullName" class="form-control" required /><span asp-validation-for="FullName" class="text-danger small"></span></div>
        <div class="mb-3"><label asp-for="Nationality" class="form-label"></label><input asp-for="Nationality" class="form-control" /><span asp-validation-for="Nationality" class="text-danger small"></span></div>
        <div class="mb-4"><label asp-for="DateOfBirth" class="form-label"></label><input asp-for="DateOfBirth" class="form-control" type="date" /><span asp-validation-for="DateOfBirth" class="text-danger small"></span></div>
        <button type="submit" class="btn btn-primary">Save author</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
