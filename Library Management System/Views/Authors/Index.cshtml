@model IEnumerable<System.Models.Author>
@{
    ViewData["Title"] = "Authors";
}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <p class="text-muted mb-0">Author master records power every title in the catalogue.</p>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add author</a>
</div>
<div class="card-surface table-card">
    <div class="table-responsive">
        <table class="table table-modern align-middle mb-0">
            <thead><tr><th>Name</th><th>Nationality</th><th>Born</th><th class="text-center">Books</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.FullName</td>
                        <td class="text-muted">@(item.Nationality ?? "—")</td>
                        <td>@item.DateOfBirth</td>
                        <td class="text-center"><span class="badge badge-status badge-borrowed">@item.Books.Count</span></td>
                        <td class="text-end action-cluster">
                            <a asp-action="Details" asp-route-id="@item.AuthorId" class="btn btn-outline-secondary btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.AuthorId" class="btn btn-outline-secondary btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.AuthorId" class="btn btn-outline-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
