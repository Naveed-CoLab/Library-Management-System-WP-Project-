@model System.Models.Book
@{
    ViewData["Title"] = "Book details";
    var busy = ViewBag.BusyItemIds as HashSet<int> ?? new HashSet<int>();
    var total = Model.Items.Count;
    var avail = Model.Items.Count(i => !busy.Contains(i.BookItemId));
}
<div class="row g-4">
    <div class="col-lg-7">
        <div class="card-surface p-4">
            <div class="d-flex flex-wrap gap-2 mb-3">
                @if (avail <= 0)
                {
                    <span class="badge badge-status badge-overdue">All copies loaned</span>
                }
                else
                {
                    <span class="badge badge-status" style="background:rgba(5,150,105,.15);color:var(--success);">@avail shelf-ready</span>
                }
                <span class="badge badge-status badge-borrowed">@total tracked copies</span>
                @if (ViewBag.ActiveReservationCount is int rc && rc > 0)
                {
                    <span class="badge badge-status"><i class="bi bi-bookmark me-1"></i>@rc wait-list</span>
                }
            </div>
            <dl class="row mb-0 small">
                <dt class="col-sm-4 text-muted">Title</dt>
                <dd class="col-sm-8 fw-semibold">@Model.Title</dd>
                <dt class="col-sm-4 text-muted">Author</dt>
                <dd class="col-sm-8">@Model.Author?.FullName</dd>
                <dt class="col-sm-4 text-muted">Category</dt>
                <dd class="col-sm-8">@Model.Category?.Name</dd>
                <dt class="col-sm-4 text-muted">Publisher</dt>
                <dd class="col-sm-8">@(Model.Publisher?.Name ?? "—")</dd>
                <dt class="col-sm-4 text-muted">Year</dt>
                <dd class="col-sm-8">@Model.PublishedYear</dd>
                <dt class="col-sm-4 text-muted">ISBN</dt>
                <dd class="col-sm-8"><span class="text-muted">@(Model.ISBN ?? "—")</span></dd>
            </dl>
            @if (!string.IsNullOrWhiteSpace(Model.Summary))
            {
                <p class="text-muted small mt-3 mb-0">@Model.Summary</p>
            }
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card-surface p-4 mb-4">
            <h3 class="h6" style="font-family:var(--font-display); font-weight:600;">Operations</h3>
            <p class="text-muted small mb-0">Place holds from Reservations. Checkout chooses a specific barcode.</p>
            <div class="d-flex flex-wrap gap-2 mt-3">
                <a asp-action="Edit" asp-route-id="@Model.BookId" class="btn btn-primary">Edit record</a>
                <a asp-controller="BorrowRecords" asp-action="Create" class="btn btn-outline-secondary">Checkout copy</a>
                <a asp-controller="Reservations" asp-action="Create" class="btn btn-outline-secondary">New hold</a>
            </div>
        </div>
    </div>
</div>

<div class="card-surface table-card p-3 p-md-4 mt-4">
    <h3 class="h6 mb-3" style="font-family:var(--font-display); font-weight:600;">Physical copies</h3>
    <div class="table-responsive">
        <table class="table table-modern mb-0">
            <thead><tr><th>Barcode</th><th>Branch</th><th>Shelf</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var i in Model.Items.OrderBy(x => x.Barcode))
                {
                    var outLoan = busy.Contains(i.BookItemId);
                    <tr>
                        <td class="fw-semibold font-monospace">@i.Barcode</td>
                        <td>@i.Branch.Name</td>
                        <td class="text-muted">@(i.ShelfLocation ?? "—")</td>
                        <td>
                            @if (outLoan)
                            {
                                <span class="badge badge-status badge-borrowed">On loan</span>
                            }
                            else
                            {
                                <span class="badge badge-status badge-returned">Available</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card-surface table-card p-3 p-md-4 mt-4">
    <h3 class="h6 mb-3" style="font-family:var(--font-display); font-weight:600;">Loan history (all copies)</h3>
    @{
        var history = Model.Items.SelectMany(i => i.BorrowRecords.Select(br => (br, i.Barcode))).OrderByDescending(x => x.br.BorrowDate).ToList();
    }
    @if (history.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-modern mb-0">
                <thead><tr><th>Copy</th><th>Member</th><th>Borrowed</th><th>Due</th><th>Returned</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var (br, barcode) in history)
                    {
                        <tr>
                            <td class="font-monospace small">@barcode</td>
                            <td>@br.Member.FullName</td>
                            <td>@br.BorrowDate</td>
                            <td>@(br.DueDate?.ToString() ?? "—")</td>
                            <td>@(br.ReturnDate?.ToString() ?? "—")</td>
                            <td>@br.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state py-4">No circulation history yet.</div>
    }
</div>
<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Back to catalogue</a>
</div>
