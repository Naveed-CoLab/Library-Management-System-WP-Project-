@model IEnumerable<System.Models.Reservation>
@{ ViewData["Title"] = "Reservations"; }
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <p class="text-muted mb-0">Title-level holds queue. Checkout automatically fulfills matching waits.</p>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New hold</a>
</div>
<div class="card-surface table-card">
    <div class="table-responsive">
        <table class="table table-modern align-middle mb-0">
            <thead><tr><th>Patron</th><th>Title</th><th>Reserved</th><th>Expires</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="fw-semibold">@r.Member.FullName</td>
                        <td>@r.Book.Title <span class="text-muted small">· @r.Book.Author.FullName</span></td>
                        <td>@r.ReservedAt.ToLocalTime().ToString("g")</td>
                        <td class="text-muted">@(r.ExpiresOn?.ToString() ?? "—")</td>
                        <td><span class="badge badge-status @(r.Status == ReservationRules.Waiting ? "badge-borrowed" : "badge-returned")">@r.Status</span></td>
                        <td class="text-end">
                            @if (r.Status == ReservationRules.Waiting)
                            {
                                <form asp-action="Cancel" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@r.ReservationId" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
