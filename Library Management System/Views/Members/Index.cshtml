@model IEnumerable<System.Models.Member>
@{
    ViewData["Title"] = "Members";
}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <p class="text-muted mb-0">Patron directory with contact info and membership start dates.</p>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Register member</a>
</div>
<div class="card-surface table-card">
    <div class="table-responsive">
        <table class="table table-modern align-middle mb-0">
            <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Member since</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.FullName</td>
                        <td><a href="mailto:@item.Email" class="text-decoration-none">@item.Email</a></td>
                        <td class="text-muted">@(item.Phone ?? "—")</td>
                        <td>@item.MemberSince</td>
                        <td class="text-end action-cluster">
                            <a asp-action="Details" asp-route-id="@item.MemberId" class="btn btn-outline-secondary btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.MemberId" class="btn btn-outline-secondary btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.MemberId" class="btn btn-outline-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
