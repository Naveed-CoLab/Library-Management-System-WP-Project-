@model AdminMemberCreateViewModel
@{ ViewData["Title"] = "Register member"; }
<div class="card-surface form-card p-4">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <div class="mb-3"><label asp-for="FullName" class="form-label"></label><input asp-for="FullName" class="form-control" required /><span asp-validation-for="FullName" class="text-danger small"></span></div>
        <div class="mb-3"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" type="email" required /><span asp-validation-for="Email" class="text-danger small"></span></div>
        <div class="mb-3"><label asp-for="Phone" class="form-label"></label><input asp-for="Phone" class="form-control" /><span asp-validation-for="Phone" class="text-danger small"></span></div>
        <div class="mb-3"><label asp-for="MemberSince" class="form-label"></label><input asp-for="MemberSince" class="form-control" type="date" /><span asp-validation-for="MemberSince" class="text-danger small"></span></div>
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Create account</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
