@model System.Models.Member
@{
    ViewData["Title"] = "Member profile";
}
<div class="card-surface p-4 mb-4">
    <dl class="row mb-0 small">
        <dt class="col-sm-3 text-muted">Name</dt>
        <dd class="col-sm-9 fw-semibold">@Model.FullName</dd>
        <dt class="col-sm-3 text-muted">Email</dt>
        <dd class="col-sm-9"><a href="mailto:@Model.Email">@Model.Email</a></dd>
        <dt class="col-sm-3 text-muted">Phone</dt>
        <dd class="col-sm-9">@(Model.Phone ?? "—")</dd>
        <dt class="col-sm-3 text-muted">Member since</dt>
        <dd class="col-sm-9">@Model.MemberSince</dd>
    </dl>
    <div class="mt-3 d-flex flex-wrap gap-2">
        <a asp-action="Edit" asp-route-id="@Model.MemberId" class="btn btn-primary btn-sm">Edit</a>
        <a asp-controller="BorrowRecords" asp-action="Create" class="btn btn-outline-secondary btn-sm">New checkout</a>
        <a asp-controller="Reservations" asp-action="Create" class="btn btn-outline-secondary btn-sm">Place hold</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
    </div>
</div>
<div class="card-surface table-card p-3 p-md-4">
    <h3 class="h6 mb-3" style="font-family:var(--font-display); font-weight:600;">Borrowing history</h3>
    @if (Model.BorrowRecords.Any())
    {
        <div class="table-responsive">
            <table class="table table-modern mb-0">
                <thead><tr><th>Barcode</th><th>Book</th><th>Author</th><th>Borrowed</th><th>Due</th><th>Returned</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var br in Model.BorrowRecords.OrderByDescending(x => x.BorrowDate))
                    {
                        <tr>
                            <td class="font-monospace small">@br.BookItem.Barcode</td>
                            <td class="fw-semibold">@br.BookItem.Book.Title</td>
                            <td class="text-muted">@br.BookItem.Book.Author.FullName</td>
                            <td>@br.BorrowDate</td>
                            <td>@(br.DueDate?.ToString() ?? "—")</td>
                            <td>@(br.ReturnDate?.ToString() ?? "—")</td>
                            <td>@br.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted small mb-0">No loans yet.</p>
    }
</div>
