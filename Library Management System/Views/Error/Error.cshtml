@model ErrorViewModel
@{
    ViewData["Title"] = "Something went wrong";
}

<div class="card-surface p-4 p-md-5 text-center">
    <i class="bi bi-exclamation-octagon fs-1 d-block mb-3 text-danger"></i>
    <h2 class="panel-title">Something went wrong</h2>
    <p class="text-muted mb-4">The request could not be completed. The issue has been logged for review.</p>
    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">Request ID: <span class="font-monospace">@Model.RequestId</span></p>
    }
    <a asp-area="" asp-controller="UserAuth" asp-action="Login" class="btn btn-primary">Back to user login</a>
</div>
