@model System.Models.BorrowRecord
@{ ViewData["Title"] = "Edit loan"; }
<div class="card-surface form-card p-4">
    <form asp-action="Edit">
        <input type="hidden" asp-for="BorrowRecordId" />
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <div class="mb-3">
            <label asp-for="MemberId" class="form-label"></label>
            <select asp-for="MemberId" asp-items="ViewBag.MemberId" class="form-select"></select>
        </div>
        <div class="mb-3">
            <label asp-for="BookItemId" class="form-label">Copy</label>
            <select asp-for="BookItemId" asp-items="ViewBag.BookItemId" class="form-select"></select>
        </div>
        <div class="mb-3">
            <label asp-for="BorrowDate" class="form-label"></label>
            <input asp-for="BorrowDate" class="form-control" type="date" />
        </div>
        <div class="mb-3">
            <label asp-for="DueDate" class="form-label"></label>
            <input asp-for="DueDate" class="form-control" type="date" />
        </div>
        <div class="mb-3">
            <label asp-for="ReturnDate" class="form-label"></label>
            <input asp-for="ReturnDate" class="form-control" type="date" />
            <span class="form-text text-muted">Setting a return closes the loan.</span>
        </div>
        <div class="mb-4">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-select">
                <option value="@LoanRules.StatusBorrowed">@LoanRules.StatusBorrowed</option>
                <option value="@LoanRules.StatusReturned">@LoanRules.StatusReturned</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Save changes</button>
        <a asp-action="Index" asp-route-filter="all" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
