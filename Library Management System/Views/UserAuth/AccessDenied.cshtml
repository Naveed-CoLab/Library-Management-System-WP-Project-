@{
    ViewData["Title"] = "User access denied";
}

<div class="card-surface p-4 p-md-5 text-center">
    <i class="bi bi-shield-lock fs-1 d-block mb-3 text-danger"></i>
    <h2 class="panel-title">Access denied</h2>
    <p class="text-muted mb-4">Your member account does not have permission to open this page.</p>
    <a asp-controller="UserAuth" asp-action="Login" class="btn btn-primary">Back to user login</a>
</div>
